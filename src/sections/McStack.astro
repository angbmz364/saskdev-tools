---
import Section from "../components/Section.astro";
import PluginBadge from "../components/PluginBadge.astro";

const plugins = [
  { name: "Spigot API", category: "core" },
  { name: "Paper API", category: "core" },
  { name: "Skript", category: "plugin" },
  { name: "SkUtilities", category: "plugin" },
  { name: "ConditionalEvents", category: "plugin" },
  { name: "MythicMobs", category: "plugin" },
  { name: "EssentialsX", category: "plugin" },
  { name: "LuckPerms", category: "plugin" },
  { name: "Vault", category: "plugin" },
  { name: "PlaceholderAPI", category: "plugin" },
  { name: "DeluxeMenus", category: "plugin" },
  { name: "zMenu", category: "plugin" },
  { name: "Multiverse-Core", category: "plugin" },
  { name: "WorldEdit", category: "plugin" },
  { name: "WorldGuard", category: "plugin" },
  { name: "ProtocolLib", category: "plugin" },
  { name: "Citizens", category: "plugin" },
  { name: "Dynmap", category: "plugin" },
];
---
<Section classes="sm:items-start py-12 md:py-16" id="stack">
  <div class="w-full max-w-240">
    <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between gap-4 mb-6">
      <div>
        <h2 class="text-3xl font-semibold text-gray-100">Mi Stack de Plugins</h2>
      </div>
      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-12 text-blue-500/30">
        <path stroke-linecap="round" stroke-linejoin="round" d="M17.593 3.322c1.1.128 1.907 1.077 1.907 2.185V21L12 17.25 4.5 21V5.507c0-1.108.806-2.057 1.907-2.185a48.507 48.507 0 0 1 11.186 0z" />
      </svg>
    </div>

    <div class="flex flex-wrap gap-2">
      {plugins.map(p => <PluginBadge name={p.name} category={p.category} />)}
    </div>
  </div>
</Section>