---
import Section from "../components/Section.astro";
import Button from "../components/Button.astro";
---
<Section classes="h-[90dvh] sm:flex-row">
  <article class="flex flex-col justify-center h-full">
    <h1 class="text-4xl md:text-5xl lg:text-6xl w-2xs md:w-lg py-3 font-bold text-gray-100 leading-tight">
      Desarrollo de Plugins<br />y Herramientas
    </h1>
    <p class="w-2xs md:w-lg text-xl py-3 text-gray-400">
      +5 años de experiencia creando plugins, configurando servidores y construyendo herramientas para comunidades Minecraft en Español.
    </p>
    <section class="py-3 text-sm md:text-md w-2xs flex items-center gap-4">
      <Button content="Herramientas" href="/tools" target="_self">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="size-5">
  <path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 0 1 1.37.49l1.296 2.247a1.125 1.125 0 0 1-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 0 1 0 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 0 1-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 0 1-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.94-1.11.94h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 0 1-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 0 1-1.369-.49l-1.297-2.247a1.125 1.125 0 0 1 .26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 0 1 0-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 0 1-.26-1.43l1.297-2.247a1.125 1.125 0 0 1 1.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28Z" />
  <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
</svg>

      </Button>
      <Button content="GitHub" href="https://github.com/angbmz364" target="_blank">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4" /><path d="M9 18c-4.51 2-5-2-7-2" /></svg>
      </Button>
    </section>
  </article>
  <div class="relative flex items-center justify-center size-50 lg:size-65">
    <div class="absolute w-full h-full bg-gray-800/40 border border-gray-700 rounded-2xl transform rotate-6 translate-x-3 translate-y-3 transition-transform hover:rotate-12 hover:translate-x-4 hover:translate-y-4 duration-500"></div>
    <div class="absolute w-4/5 h-4/5 bg-gray-700/40 border border-gray-600 rounded-xl transform -rotate-3 -translate-x-1 translate-y-1 transition-transform hover:-rotate-6 hover:-translate-x-2 hover:translate-y-2 duration-500"></div>
    <div class="relative w-full h-full bg-gray-900 border border-blue-500/50 rounded-xl flex items-center justify-center group overflow-hidden">
      <div class="absolute inset-0 grid grid-cols-3 grid-rows-3">
        <div class="border border-green-500/30 bg-green-500/20"></div>
        <div class="border border-green-500/30 bg-green-500/20"></div>
        <div class="border border-green-500/30 bg-green-500/20"></div>
        <div class="border border-green-500/30 bg-green-500/20"></div>
        <div class="border border-green-500/30 bg-green-500/30"></div>
        <div class="border border-green-500/30 bg-green-500/20"></div>
        <div class="border border-green-500/30 bg-green-500/20"></div>
        <div class="border border-green-500/30 bg-green-500/20"></div>
        <div class="border border-green-500/30 bg-green-500/20"></div>
      </div>
      <div class="relative z-10">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="3" stroke="currentColor" class="w-10 h-10 text-green-400/80">
          <path stroke-linecap="round" stroke-linejoin="round" d="M6.75 8.25h10.5m-10.5 3h10.5m-10.5 3h10.5m-10.5 3h10.5" />
        </svg>
      </div>
      <div class="absolute -bottom-2 -right-2 bg-blue-500 text-gray-900 text-[10px] font-mono px-2 py-0.5 rounded border border-gray-800">v1.0</div>
    </div>
  </div>
</Section>
