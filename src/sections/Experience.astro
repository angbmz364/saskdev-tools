---
const experience = [
  {
    title: "Desarrollador Fullstack en DiofStudios",
    date: "12 Marzo, 2026 - Hasta la fecha",
    target: "_blank",
    url: "https://diofstudios.com",
    content:
      "Encargado de el desarrollo, despliegue y mantenimiento de la página oficial de la empresa. A su vez soy parte del equipo técnico y desarrollo como desarrollador Frontend.",
  },
  {
    title: "Configurador de Servidores de Minecraft",
    date: "15 Septiembre, 2025 - 2 Marzo, 2026",
    target: "_self",
    url: "/minecraft",
    content:
      "Durante mucho tiempo me dediqué al desarrollo de servidores de Minecraft, contribuyendo en muchos servidores como desarrollador de plugins y configurador de servidores. Tambien gracias a este periodo, decidí crear un proyecto capaz de agilizar el trabajo en los servidores de minecraft.",
  },
];
---

<h2
  class="text-3xl flex items-center justify-center sm:justify-start gap-3 w-full font-semibold"
>
  <svg
    xmlns="http://www.w3.org/2000/svg"
    fill="none"
    viewBox="0 0 24 24"
    stroke-width="2"
    stroke="currentColor"
    class="size-8"
  >
    <path
      stroke-linecap="round"
      stroke-linejoin="round"
      d="M20.25 14.15v4.25c0 1.094-.787 2.036-1.872 2.18-2.087.277-4.216.42-6.378.42s-4.291-.143-6.378-.42c-1.085-.144-1.872-1.086-1.872-2.18v-4.25m16.5 0a2.18 2.18 0 0 0 .75-1.661V8.706c0-1.081-.768-2.015-1.837-2.175a48.114 48.114 0 0 0-3.413-.387m4.5 8.006c-.194.165-.42.295-.673.38A23.978 23.978 0 0 1 12 15.75c-2.648 0-5.195-.429-7.577-1.22a2.016 2.016 0 0 1-.673-.38m0 0A2.18 2.18 0 0 1 3 12.489V8.706c0-1.081.768-2.015 1.837-2.175a48.111 48.111 0 0 1 3.413-.387m7.5 0V5.25A2.25 2.25 0 0 0 13.5 3h-3a2.25 2.25 0 0 0-2.25 2.25v.894m7.5 0a48.667 48.667 0 0 0-7.5 0M12 12.75h.008v.008H12v-.008Z"
    ></path>
  </svg>
  Experiencia laboral
</h2>
<ol
  class="flex items-center flex-col justify-center sm:justify-start w-full mt-8"
>
  {
    experience.map(({ title, date, content, url, target }) => (
      <li class="max-w-xs sm:max-w-full mb-4">
        <div class="mt-3 flex flex-col items-start justify-start">
          <time
            class="
            text-sm uppercase font-semibold text-blue-500 mb-2
            "
          >
            {date}
          </time>
          <h3 class="text-2xl text-gray-100 font-semibold">{title}</h3>
        </div>
        <p class="text-gray-200 text-md pb-3 mt-1">{content}</p>
        <a
          href={url}
          target={target}
          class="
          inline-flex gap-3 items-center justify-center rounded-3xl transition-all duration-150 text-blue-500 uppercase font-semibold text-sm md:text-md
          hover:translate-x-1
          "
        >
          Ver página
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke="currentColor"
            class="size-4"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M13.5 4.5 21 12m0 0-7.5 7.5M21 12H3"
            />
          </svg>
        </a>
      </li>
    ))
  }
</ol>
