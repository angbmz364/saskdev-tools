---
import Layout from "../../layouts/ToolLayout.astro";
---

<Layout
    title="SaskDev - Menu Tools"
    description="Convierte rápida y fielmente tus configuraciones de zMenu a DeluxeMenus y viceversa manteniendo ítems, acciones y parámetros esenciales."
>
    <main class="flex flex-col items-center">
        <!-- hero -->
        <section
            class="flex flex-col items-start max-w-240 w-[90dvw] justify-center h-[80dvh]"
        >
            <h1
                class="text-4xl md:text-5xl w-2xs md:w-lg py-3 font-bold flex gap-3 items-center justify-start"
            >
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                    stroke-width="3"
                    stroke="currentColor"
                    class="size-10 text-blue-500"
                >
                    <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        d="M7.5 21 3 16.5m0 0L7.5 12M3 16.5h13.5m0-13.5L21 7.5m0 0L16.5 12M21 7.5H7.5"
                    ></path>
                </svg>
                Menu Converter
            </h1>
            <p class="w-2xs md:w-lg text-xl py-3 text-gray-200">
                Una útil herramienta capaz de convertir menus de un plugin a
                otro, manteniendo todo el contenido y estructura.
                <span class="text-blue-500 font-semibold"
                    >Y todo al instante.</span
                >
            </p>
        </section>

        <!-- interface -->
        <div
            class="w-full bg-neutral-900/20 border border-neutral-800 backdrop-blur-md rounded-3xl p-6 shadow-2xl flex flex-col gap-6 -mt-2"
        >
            <div
                class="flex flex-col md:flex-row items-center justify-between gap-4 w-full bg-neutral-950/60 p-4 rounded-2xl border border-neutral-800/80"
            >
                <div class="flex items-center gap-3 w-full md:w-auto">
                    <label
                        for="conversionDirection"
                        class="text-gray-300 font-medium whitespace-nowrap"
                        >Modo de Conversión:</label
                    >
                    <div class="relative w-full md:w-auto">
                        <select
                            id="conversionDirection"
                            class="w-full md:w-auto appearance-none bg-neutral-900/20 text-gray-100 px-4 py-2 pr-10 rounded-xl border border-neutral-800 outline-none focus:border-blue-500 focus:ring-1 focus:ring-blue-500 transition-all font-medium cursor-pointer"
                        >
                            <option value="dm2zm">DeluxeMenus a zMenu</option>
                            <option value="zm2dm">zMenu a DeluxeMenus</option>
                        </select>
                        <div
                            class="pointer-events-none absolute inset-y-0 right-0 flex items-center px-3 text-gray-400"
                        >
                            <svg
                                class="w-4 h-4"
                                fill="none"
                                stroke="currentColor"
                                viewBox="0 0 24 24"
                                ><path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    stroke-width="2"
                                    d="M19 9l-7 7-7-7"></path></svg
                            >
                        </div>
                    </div>
                </div>

                <button
                    id="convertBtn"
                    class="w-full md:w-auto flex items-center justify-center gap-2 bg-blue-600 hover:bg-blue-500 text-white px-8 py-2.5 rounded-xl transition-all duration-300 transform active:scale-95 shadow-lg shadow-blue-900/20 font-semibold focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 focus:ring-offset-gray-900"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        fill="none"
                        viewBox="0 0 24 24"
                        stroke-width="2"
                        stroke="currentColor"
                        class="size-5"
                    >
                        <path
                            stroke-linecap="round"
                            stroke-linejoin="round"
                            d="M16.023 9.348h4.992v-.001M2.985 19.644v-4.992m0 0h4.992m-4.993 0 3.181 3.183a8.25 8.25 0 0 0 13.803-3.7M4.031 9.865a8.25 8.25 0 0 1 13.803-3.7l3.181 3.182m0-4.991v4.99"
                        ></path>
                    </svg>
                    Convertir YAML
                </button>
            </div>

            <div
                id="alertBox"
                class="hidden w-full p-4 rounded-xl text-sm font-medium items-center gap-2 transition-all duration-300"
            >
            </div>

            <div
                class="grid grid-cols-1 md:grid-cols-2 gap-4 h-[65vh] min-h-[450px]"
            >
                <!-- inoput -->
                <div
                    class="flex flex-col h-full rounded-2xl border border-neutral-800 overflow-hidden relative group bg-neutral-950/80 focus-within:border-blue-500/50 focus-within:ring-1 focus-within:ring-blue-500/30 transition-all"
                >
                    <div
                        class="bg-neutral-800/60 px-4 py-3 border-b border-neutral-700/80 flex justify-between items-center backdrop-blur-sm"
                    >
                        <span
                            id="sourceLabel"
                            class="font-semibold text-gray-200"
                            >DeluxeMenus (Entrada)</span
                        >
                    </div>
                    <textarea
                        id="sourceEditor"
                        class="w-full h-full bg-transparent text-gray-300 p-4 font-mono text-sm resize-none outline-none custom-scrollbar leading-relaxed"
                        placeholder="Pega tu configuración YAML aquí..."
                        spellcheck="false"
                        aria-label="Editor de código de entrada"></textarea>
                </div>

                <!-- output -->
                <div
                    class="flex flex-col h-full rounded-2xl border border-neutral-800 overflow-hidden relative group bg-neutral-950/50"
                >
                    <div
                        class="bg-neutral-800/40 px-4 py-3 border-b border-neutral-800 flex justify-between items-center backdrop-blur-sm"
                    >
                        <span
                            id="resultLabel"
                            class="font-semibold text-blue-400"
                            >zMenu (Salida)</span
                        >
                        <button
                            id="copyBtn"
                            class="text-gray-400 hover:text-white transition-transform active:scale-90"
                            aria-label="Copiar al portapapeles"
                            title="Copiar al portapapeles"
                        >
                            <svg
                                xmlns="http://www.w3.org/2000/svg"
                                fill="none"
                                viewBox="0 0 24 24"
                                stroke-width="2"
                                stroke="currentColor"
                                class="w-5 h-5"
                            >
                                <path
                                    stroke-linecap="round"
                                    stroke-linejoin="round"
                                    d="M15.75 17.25v3.375c0 .621-.504 1.125-1.125 1.125h-9.75a1.125 1.125 0 0 1-1.125-1.125V7.875c0-.621.504-1.125 1.125-1.125H6.75a9.06 9.06 0 0 1 1.5.124m7.5 10.376h3.375c.621 0 1.125-.504 1.125-1.125V11.25c0-4.46-3.243-8.161-7.5-8.876a9.06 9.06 0 0 0-1.5-.124H9.375c-.621 0-1.125.504-1.125 1.125v3.5m7.5 10.375H9.375a1.125 1.125 0 0 1-1.125-1.125v-9.25m12 6.625v-1.875a3.375 3.375 0 0 0-3.375-3.375h-1.5a1.125 1.125 0 0 1-1.125-1.125v-1.5a3.375 3.375 0 0 0-3.375-3.375H9.75"
                                ></path>
                            </svg>
                        </button>
                    </div>
                    <textarea
                        id="resultEditor"
                        class="w-full h-full bg-transparent p-4 text-blue-300 font-mono text-sm resize-none outline-none custom-scrollbar leading-relaxed"
                        readonly
                        placeholder="Aquí aparecerá el código convertido..."
                        aria-label="Editor de código de salida (solo lectura)"
                    ></textarea>
                </div>
            </div>
        </div>
    </main>
</Layout>

<!-- logic of menu convertor-->
<script>
    import { convertDMtoZM, convertZMtoDM } from "../../libs/menuConverter.js";

    document.addEventListener("DOMContentLoaded", () => {
        const $ = (id) => document.getElementById(id);
        const sourceEditor = $("sourceEditor");
        const resultEditor = $("resultEditor");
        const convertBtn = $("convertBtn");
        const copyBtn = $("copyBtn");
        const conversionDirection = $("conversionDirection");
        const sourceLabel = $("sourceLabel");
        const resultLabel = $("resultLabel");
        const alertBox = $("alertBox");

        // change text according to the selected direction
        conversionDirection.addEventListener("change", () => {
            if (conversionDirection.value === "dm2zm") {
                sourceLabel.textContent = "DeluxeMenus (Entrada)";
                resultLabel.textContent = "zMenu (Salida)";
            } else {
                sourceLabel.textContent = "zMenu (Entrada)";
                resultLabel.textContent = "DeluxeMenus (Salida)";
            }
            sourceEditor.value = "";
            resultEditor.value = "";
            hideAlert();
        });

        // universal alert function
        const showAlert = (message, isError = true) => {
            alertBox.innerHTML = `
            <div class="flex items-start gap-3">
                ${
                    isError
                        ? '<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"></path></svg>'
                        : '<svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 flex-shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>'
                }
                <span>${message.replace(/\n/g, "<br>")}</span>
            </div>
        `;
            alertBox.className =
                "w-full p-4 rounded-xl text-sm font-medium items-center gap-2 transition-all duration-300 flex";
            if (isError) {
                alertBox.classList.add(
                    "bg-red-950/40",
                    "text-red-400",
                    "border",
                    "border-red-900/50",
                );
            } else {
                alertBox.classList.add(
                    "bg-green-950/40",
                    "text-green-400",
                    "border",
                    "border-green-900/50",
                );
            }
        };

        const hideAlert = () => {
            alertBox.classList.add("hidden");
            alertBox.classList.remove("flex");
        };

        convertBtn.addEventListener("click", () => {
            hideAlert();
            let sourceCode = sourceEditor.value.trim();

            if (!sourceCode) {
                showAlert(
                    "Por favor, pega el código YAML de origen para poder realizar la conversión.",
                );
                return;
            }

            try {
                let yamlStr;
                if (conversionDirection.value === "dm2zm") {
                    yamlStr = convertDMtoZM(sourceCode);
                } else {
                    yamlStr = convertZMtoDM(sourceCode);
                }

                resultEditor.value = yamlStr;
                showAlert(
                    "Conversión generada exitosamente. Verifica el resultado en la salida debajo.",
                    false,
                );
            } catch (e) {
                console.error(e);
                showAlert(
                    `Mala sintaxis detectada. No pudimos leer el archivo YAML:<br>${e.message}`,
                );
            }
        });

        copyBtn.addEventListener("click", () => {
            if (!resultEditor.value) return;
            navigator.clipboard.writeText(resultEditor.value).then(() => {
                const originalHTML = copyBtn.innerHTML;
                copyBtn.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="2" stroke="currentColor" class="w-5 h-5 text-green-400"><path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5" /></svg>`;
                setTimeout(() => {
                    copyBtn.innerHTML = originalHTML;
                }, 2000);
            });
        });
    });
</script>
